{
  "manifest_version": 3,
  "name": "MidTerm Mobile Device Bridge",
  "version": "1.0.0",
  "description": "Open remote MidTerm previews in a local Pixel 8 Chrome device with touch, rotation, lifecycle, keyboard, and screenshots.",
  "minimum_chrome_version": "120",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": ["activeTab", "debugger", "scripting", "storage", "tabs"],
  "action": {
    "default_title": "Connect this MidTerm tab",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      }
    }
  },
  "background": {
    "service_worker": "service-worker.js"
  }
}
